<Window x:Class="NetworkAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализатор сетевых подключений" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Анализатор сетевых подключений" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10"/>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="0,10,0,0">
            <!-- Вкладка сетевых интерфейсов -->
            <TabItem Header="Сетевые интерфейсы" IsSelected="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Список интерфейсов -->
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="5">
                        <DockPanel>
                            <TextBlock Text="Сетевые интерфейсы:" 
                                       FontWeight="Bold" Margin="0,0,0,5" DockPanel.Dock="Top"/>
                            <ListBox x:Name="InterfacesListBox" 
                                     DisplayMemberPath="Name"
                                     SelectionChanged="InterfacesListBox_SelectionChanged"
                                     Background="White" BorderThickness="1"/>
                        </DockPanel>
                    </Border>

                    <!-- Детальная информация -->
                    <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" 
                            CornerRadius="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Информация об интерфейсе:" 
                                       FontWeight="Bold" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Имя:" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="InterfaceNameText" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                           Margin="0,5" FontWeight="Bold"/>

                                <TextBlock Text="Описание:" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="InterfaceDescText" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                           Margin="0,5" TextWrapping="Wrap"/>

                                <TextBlock Text="IP-адрес:" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="InterfaceIpText" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                           Margin="0,5" FontWeight="Bold"/>

                                <TextBlock Text="Маска подсети:" Grid.Row="3" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="InterfaceMaskText" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" 
                                           Margin="0,5"/>

                                <TextBlock Text="MAC-адрес:" Grid.Row="4" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="InterfaceMacText" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" 
                                           Margin="0,5"/>

                                <TextBlock Text="Состояние:" Grid.Row="5" Grid.Column="0" Margin="0,5"/>
                                <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" 
                                           Orientation="Horizontal" Margin="0,5">
                                    <Ellipse x:Name="StatusIndicator" Width="10" Height="10" 
                                             Margin="0,5,5,5"/>
                                    <TextBlock x:Name="InterfaceStatusText" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="Скорость:" Grid.Row="6" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="InterfaceSpeedText" Grid.Row="6" Grid.Column="1" 
                                           Margin="0,5" FontWeight="Bold"/>
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="(1 Мбит/с = 1 000 000 бит/с)" 
                                           Margin="5,5,0,5" Foreground="Gray" FontSize="10"
                                           VerticalAlignment="Center"/>

                                <TextBlock Text="Тип:" Grid.Row="7" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="InterfaceTypeText" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" 
                                           Margin="0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка анализа URL -->
            <TabItem Header="Анализ URL">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Поле ввода URL -->
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Введите URL для анализа:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DockPanel>
                                <Button x:Name="AnalyzeUrlButton" Content="Анализировать" 
                                        Width="120" DockPanel.Dock="Right" Margin="5,0,0,0"
                                        Click="AnalyzeUrlButton_Click"/>
                                <TextBox x:Name="UrlInputTextBox" Height="30" 
                                         VerticalContentAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Результаты анализа URL -->
                    <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" 
                            CornerRadius="5" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Компоненты URL:" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Схема:" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="UrlSchemeText" Grid.Row="0" Grid.Column="1" Margin="0,5"/>

                                <TextBlock Text="Хост:" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="UrlHostText" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

                                <TextBlock Text="Порт:" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="UrlPortText" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

                                <TextBlock Text="Путь:" Grid.Row="3" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="UrlPathText" Grid.Row="3" Grid.Column="1" Margin="0,5" TextWrapping="Wrap"/>

                                <TextBlock Text="Параметры:" Grid.Row="4" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="UrlQueryText" Grid.Row="4" Grid.Column="1" Margin="0,5" TextWrapping="Wrap"/>

                                <TextBlock Text="Фрагмент:" Grid.Row="5" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="UrlFragmentText" Grid.Row="5" Grid.Column="1" Margin="0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- DNS и Ping информация -->
                    <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Дополнительная информация:" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Тип адреса:" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
                                <TextBlock x:Name="AddressTypeText" Grid.Row="0" Grid.Column="1" Margin="0,5"/>

                                <TextBlock Text="DNS адреса:" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
                                <ListBox x:Name="DnsAddressesList" Grid.Row="1" Grid.Column="1" 
                                         MaxHeight="100" Margin="0,5"/>

                                <TextBlock Text="Ping результат:" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
                                    <Ellipse x:Name="PingIndicator" Width="10" Height="10" 
                                             Margin="0,5,5,5"/>
                                    <TextBlock x:Name="PingResultText"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка истории -->
            <TabItem Header="История">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button x:Name="ClearHistoryButton" Content="Очистить историю" 
                            Width="120" HorizontalAlignment="Right" Margin="5"
                            Click="ClearHistoryButton_Click"/>

                    <ListBox x:Name="HistoryListBox" Grid.Row="1" Margin="5"
                             DisplayMemberPath="OriginalUrl"
                             SelectionChanged="HistoryListBox_SelectionChanged"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Статус бар -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов к работе"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>